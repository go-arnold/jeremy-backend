# Live streaming — self-hosted MediaMTX (voir docs/vps-deployment/mediamtx.yml)
MEDIAMTX_RTMP_SERVER_URL=rtmp://votre-domaine:1935/live
MEDIAMTX_HLS_BASE_URL=https://votre-domaine/live-hls
MEDIAMTX_API_URL=http://mediamtx:9997
## MEDIAMTX_WEBHOOK_SECRET n'est PAS fourni par un tiers — choisissez vous-même une valeur
## aléatoire (ex: python3 -c "import secrets; print(secrets.token_urlsafe(32))"), et utilisez
## exactement la même valeur dans mediamtx.yml (variable $MEDIAMTX_WEBHOOK_SECRET des hooks).
MEDIAMTX_WEBHOOK_SECRET=

